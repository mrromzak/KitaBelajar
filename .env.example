# =====================================================
#  .env.example — Template konfigurasi KitaBelajar
#  Salin ke .env lalu isi nilainya:  cp .env.example .env
#  (.env TIDAK di-commit — sudah ada di .gitignore)
# =====================================================

# ── WAJIB (server tidak jalan tanpa ini) ────────────
# Dari Supabase: Project Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role_key...

# Rahasia JWT (bebas, panjang & acak). Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-panjang

# Kunci enkripsi chat & jawaban (WAJIB 64 hex / 32 byte). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Catatan: di NODE_ENV!=production, jika kosong app tetap jalan tapi data
# disimpan tanpa enkripsi (mode dev). Untuk lokal sebaiknya tetap diisi.
ENCRYPTION_KEY=

# ── Lokal/dev ────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Untuk dev biarkan kosong; isi domain bila perlu CORS lintas origin.
CORS_ORIGIN=

# ── OPSIONAL (fitur degrade dengan aman bila kosong) ─
# Email OTP registrasi (Brevo). TIDAK perlu untuk login akun yang sudah ada
# (mis. hasil seed_dummy.js). Hanya dibutuhkan saat mendaftar via OTP.
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@kitabelajar.id
BREVO_FROM_NAME=KitaBelajar
APP_URL=http://localhost:3000

# AI (Groq). Tanpa ini, fitur chatbot/AI mati tapi sisanya jalan.
GROQ_API_KEY=
# GROQ_MODEL = model untuk generate soal (zep quiz). Chat juga pakai model ini bila tak di-set di frontend.
GROQ_MODEL=openai/gpt-oss-120b
# Key cadangan opsional: GROQ_API_KEY_BACKUP1, GROQ_API_KEY_BACKUP2, dst.

# Login Google (wajib untuk sistem kode guru)
# Dapatkan dari: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JavaScript origins: http://localhost:4100 (dev) / https://yourdomain.com (prod)
# Authorized redirect URIs: tidak diperlukan (GSI One Tap tidak pakai redirect)
GOOGLE_CLIENT_ID=

# ── Prototype Kode Guru ───────────────────────────────────────
# Jalankan: node prototype/kode-guru/server.js
# JWT_SECRET, GOOGLE_CLIENT_ID, SUPABASE_URL, SUPABASE_SERVICE_KEY
# di atas dipakai bersama oleh prototype dan produksi.
#
# Port prototype (default 4100 — pakai PROTO_PORT agar tidak bentrok dengan PORT=3000):
PROTO_PORT=4100
#
# Akun kepala sekolah (dipakai oleh seed-kepala.js):
KEPALA_EMAIL=kepala@sekolah.id
KEPALA_PASS=
KEPALA_NAMA=Kepala Sekolah
#
# Langkah setup prototype:
#   1. Jalankan migration_kode_guru_v2.sql di Supabase SQL Editor
#   2. node prototype/kode-guru/seed-kepala.js   ← buat akun kepala
#   3. node prototype/kode-guru/server.js         ← jalankan server

# Text-to-speech HuggingFace (opsional)
HF_TOKEN=

# Video meeting Daily.co (opsional)
DAILY_API_KEY=

# Web push notification (opsional) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@kitabelajar.id

# Web search (opsional)
SEARXNG_URL=
